# APP_URL: The URL where this app is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional external API keys (system falls back smoothly to real-time OpenAQ/CPCB public feeds if not provided)
CPCB_API_KEY="YOUR_CPCB_API_KEY"
IMD_WEATHER_KEY="YOUR_IMD_WEATHER_KEY"
# An authorised, traceable Copernicus Browser/catalogue URL. No simulated satellite tiles are displayed.
COPERNICUS_BROWSE_URL=""
# Name/identifier of an authorised, de-identified hospital/public-health data feed.
HEALTH_DATA_SOURCE=""
# Name/identifier of a persisted feed containing observed AQI versus prior forecast pairs.
FORECAST_VALIDATION_SOURCE=""
JWT_SECRET="YOUR_JWT_SECRET"
